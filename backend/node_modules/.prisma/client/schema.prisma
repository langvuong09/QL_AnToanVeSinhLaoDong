generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id     Int     @id @default(autoincrement())
  role   String  @unique
  name   String
  type   String?
  status Boolean @default(true)

  users User[]
}

model User {
  id       String @id @default(uuid())
  username String @unique
  password String

  fullName String?
  realRole String?
  avatar   String?
  email    String?

  dateOfBirth DateTime?
  status      Boolean   @default(true)

  unitId    Int?
  deletedAt DateTime?
  doet_id   Int?
  workUnit  String?

  roleId Int?
  role   Role? @relation(fields: [roleId], references: [id])
}
